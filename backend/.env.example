# Copy to .env and set real values. Never commit .env.

# Required: generate with `python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"`
SECRET_KEY=change-me-generate-a-real-secret-key

# false in production
DEBUG=true

# Comma-separated hostnames (required when DEBUG=false)
ALLOWED_HOSTS=localhost,127.0.0.1

# When using HTTPS in production (comma-separated origins, include scheme)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Browser origins allowed to call the API (comma-separated). Ignored when DEBUG=true (all origins allowed for local dev).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: set true behind a TLS-terminating proxy that sets X-Forwarded-Proto
USE_SECURE_PROXY_HEADER=false

# Optional: redirect HTTP to HTTPS (enable only when TLS is terminated correctly)
SECURE_SSL_REDIRECT=false

# Database: omit for SQLite. Example for Postgres:
# DATABASE_URL=postgres://user:password@localhost:5432/osint_guard
