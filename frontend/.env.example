# Copy to `.env.development` for local dev (Vite loads it automatically).

# Where Vite proxies `/api` in dev. Not exposed to the browser bundle.
BACKEND_URL=http://127.0.0.1:8000

# Optional: prefix for API requests in production builds (different domain than the SPA).
# Leave unset when the same origin serves `/api` (e.g. nginx → Django).
# VITE_API_BASE_URL=https://api.example.com

# Set to "true" to use bundled dummy JSON only (skip POST /api/collect/).
# Omit or "false" for live Apify collection on /analysis.
# VITE_USE_DUMMY_DATA=true

# Geospatial view uses OpenStreetMap tiles (Leaflet) — no API key required.
# Follow https://wiki.openstreetmap.org/wiki/Tile_usage_policy for production traffic.
